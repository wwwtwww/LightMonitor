{
  "name": "lightmonitor",
  "version": "0.1.0",
  "private": true,
  "description": "LightMonitor 数据库监控工具",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "pack": "node scripts/pack.js",
    "pack:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package.ps1",
    "pack:offline": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-offline.ps1",
    "release": "node scripts/release.js",
    "dev": "vite",
    "build": "vite build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.7",
    "better-sqlite3": "^11.3.0",
    "echarts": "^5.4.3",
    "element-plus": "^2.5.3",
    "mysql2": "^3.18.2",
    "vue": "^3.4.15",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.3",
    "archiver": "^7.0.1",
    "vite": "^5.0.12"
  }
}
